# ─────────────────────────────────────────────
# Teacher Attendance App — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server port (leave as 3001 unless it conflicts)
PORT=3001

# Frontend URL for CORS (match your Vite dev server)
FRONTEND_URL=http://localhost:5173

# JWT secret — change this to a long random string in production!
JWT_SECRET=change_me_to_a_long_random_secret_key_at_least_32_chars

# JWT token expiry
JWT_EXPIRES_IN=24h
